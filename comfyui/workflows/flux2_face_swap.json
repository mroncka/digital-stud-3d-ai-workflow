{
  "_meta": {
    "title": "FLUX.2 Klein 9B - Face Swap (ReActor + GFPGAN)",
    "description": "Face swap pipeline using FLUX.2 Klein 9B for base generation, ReActor for identity transfer, and GFPGAN for restoration. Supports pre-saved Face Models (.safetensors) for repeatable character consistency. Based on Digital-Stud run #59 SOTA findings (March 2026).",
    "version": "1.0.0",
    "created": "2026-03-13",
    "tags": [
      "flux2",
      "face_swap",
      "reactor",
      "gfpgan",
      "character_consistency",
      "digital_stud"
    ],
    "required_custom_nodes": [
      "ComfyUI-ReActorFaceSwap",
      "ComfyUI-VideoHelperSuite",
      "comfyui_controlnet_aux",
      "ComfyUI_NVIDIA_RTX_Nodes"
    ],
    "model_requirements": {
      "checkpoint": "flux2-klein-9b-fp8.safetensors",
      "face_restore": "GFPGANv1.4.pth",
      "face_detect": "buffalo_l (InsightFace via onnxruntime)",
      "swap_model": "inswapper_128.onnx",
      "vae": "ae.safetensors (FLUX VAE)"
    },
    "install_notes": [
      "ComfyUI Manager -> Search 'ReActor' -> Install ComfyUI-ReActorFaceSwap",
      "ComfyUI Manager -> Search 'RTX' -> Install ComfyUI_NVIDIA_RTX_Nodes",
      "Download GFPGANv1.4.pth to ComfyUI/models/facerestore_models/",
      "Download inswapper_128.onnx to ComfyUI/models/insightface/",
      "Download buffalo_l to ComfyUI/models/insightface/models/buffalo_l/"
    ]
  },
